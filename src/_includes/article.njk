---
layout: base.njk
changeFreq: daily
robots: nosnippet
---


  <!-- Hero -->
  <section class="hero py-5 bg-info" >
    <div class="container py-5">
      <h1 class="display-5 fw-bold mb-3 text-primary">{{title }}</h1>
      
    </div>
  </section>
 <!-- Blog Detail -->
<section class="py-5 bg-light">
  <div class="container w-100">
    <div class="row justify-content-center">
      <div class="col-lg-12">
        <article class="bg-white  shadow rounded-4 shadow-sm article-content p-3">
          <img  src="{{ image }}" class="rounded-top-4 mb-4 w-100" alt="Blog Image" height="300px" style="object-fit: cover;">
          <p class="text-muted small mb-4">   By <strong>{{ author }}</strong> - {{ date | postdate }}</p>
         
          <p>
          {{ content | safe }}
          </p>
        
          <hr>
          <div class="mt-4">
           <a href="/blog" class="btn btn-outline-secondary mt-4">← Back to Blog</a>
          </div>
        </article>
      </div>
    </div>
  </div>
</section>

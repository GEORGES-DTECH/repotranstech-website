---
layout: base.njk
changeFreq: daily

---


  <!-- Hero -->
  <section class="hero py-5 bg-info" >
    <div class="container py-5">
      <h1 class="display-5 fw-bold mb-3 text-primary text-center">{{title }}</h1>
      
    </div>
  </section>
 <!-- Blog Detail -->
<section class="py-5 bg-light">
  <div class="container w-100">
    <div class="row justify-content-center">
      <div class="col-lg-12">

        <article class="bg-white shadow rounded-4 overflow-hidden">

          <img src="{{ image }}"
               class="w-100"
               alt="Blog Image"
               style="object-fit:cover;height:350px">

          <div class="article-content p-3">

            <p class="text-primary fw-smibold small mb-4">
              By <strong>{{ author }}</strong> - {{ date | postdate }}
            </p>

            {{ content | safe }}

            <hr>

            <a href="/blog" class="btn btn-outline-secondary mt-4">
              ← Back to Blog
            </a>

          </div>

        </article>

      </div>
    </div>
  </div>
</section>
